ANTHROPIC_API_KEY=
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
CHROMA_PERSIST_PATH=./chroma_db

# Deployment-safe defaults for small instances (e.g. Render free tier).
# Omit or override locally for full Chroma / Neo4j retrieval.
RETRIEVER_BACKEND=keyword
POLICY_GRAPH_BACKEND=memory
BUILD_INDEX_ON_STARTUP=false

# LangSmith tracing (optional — remove or leave blank to disable)
# Get your API key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=gaggia-agent
